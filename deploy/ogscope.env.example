# OGScope 主配置示例 / Primary deployment configuration example
# 部署路径 / Deploy path: /etc/ogscope/ogscope.env
# 本地开发可复制为项目根 .env / For local dev, copy to project root .env
#
# 所有键均对应 ogscope.config.Settings（前缀 OGSCOPE_）。
# 未列出的项使用代码默认值；完整目录见 deploy/network.env.example 与 Web 配置页「配置目录」。
# All keys map to ogscope.config.Settings (OGSCOPE_ prefix). Omitted keys use code defaults.

# --- 基础 / Basic ---
OGSCOPE_ENVIRONMENT=production
OGSCOPE_DEBUG=false
OGSCOPE_DEVELOPMENT_MODE=false
OGSCOPE_LOG_LEVEL=INFO
# OGSCOPE_LOG_FILE=/var/log/ogscope/app.log
# OGSCOPE_SIMULATION_MODE=auto
# OGSCOPE_FORCE_EXIT_ON_SHUTDOWN=true

# --- Web 服务 / Web service ---
OGSCOPE_HOST=0.0.0.0
OGSCOPE_PORT=8000
OGSCOPE_RELOAD=false

# --- 硬件平面 / Hardware plane ---
# OGSCOPE_HARDWARE_PLANE_ENABLED=true
# OGSCOPE_HARDWARE_PLANE_ROLE=standalone
# OGSCOPE_HARDWARE_PLANE_RPC_TIMEOUT_MS=800
# OGSCOPE_HARDWARE_PLANE_UDS_SOCKET=/tmp/ogscope-hardware-plane.sock
# OGSCOPE_HARDWARE_PLANE_REMOTE_UDS_SOCKET=/tmp/external-sensor-plane.sock
# OGSCOPE_HARDWARE_PLANE_CAMERA_AUTOSTART=false
# OGSCOPE_ENABLE_LOCAL_SENSORS=true
# OGSCOPE_ENABLE_HMI=true
# OGSCOPE_ENABLE_UI=true
# OGSCOPE_SUBORDINATE_LOCAL_DEV_ONLY=false

# --- 相机 / Camera ---
# OGSCOPE_CAMERA_TYPE=imx327_mipi
# OGSCOPE_CAMERA_WIDTH=1280
# OGSCOPE_CAMERA_HEIGHT=720
# OGSCOPE_CAMERA_FPS=5
# OGSCOPE_CAMERA_SAMPLING_MODE=native
# OGSCOPE_CAMERA_EXPOSURE=10000
# OGSCOPE_CAMERA_GAIN=1.0
# OGSCOPE_CAMERA_AE_POLAR_PRESET=true
# OGSCOPE_CAMERA_AE_EXPOSURE_VALUE=0.35
# OGSCOPE_CAMERA_FLIP_HORIZONTAL=false
# OGSCOPE_CAMERA_FLIP_VERTICAL=false

# --- 预览与抓帧 / Preview & grabber ---
# OGSCOPE_SHARED_PREVIEW_FPS=8
# OGSCOPE_PREVIEW_JPEG_QUALITY=75
# OGSCOPE_DEBUG_PREVIEW_MIN_INTERVAL_MS=150
# OGSCOPE_CAMERA_PROBE_TIMEOUT_SEC=2.0
# OGSCOPE_CAMERA_GRAB_FAILURES_OFFLINE=3
# OGSCOPE_KEEP_RAW_CACHE=false
# OGSCOPE_STREAM_MAX_MJPEG_CLIENTS=4
# OGSCOPE_STREAM_MJPEG_FRAME_FETCH_TIMEOUT_MS=20000

# --- SPI 屏幕 / SPI display ---
# OGSCOPE_DISPLAY_ENABLED=false
# OGSCOPE_DISPLAY_TYPE=st7796
# OGSCOPE_DISPLAY_WIDTH=320
# OGSCOPE_DISPLAY_HEIGHT=320
# OGSCOPE_DISPLAY_ROTATION=0
# OGSCOPE_DISPLAY_DC_PIN=24
# OGSCOPE_DISPLAY_SPI_MAX_SPEED_HZ=16000000

# --- 极轴校准 / Polar alignment ---
# OGSCOPE_POLAR_ALIGN_TIMEOUT=300
# OGSCOPE_POLAR_ALIGN_PRECISION=1.0

# --- 路径 / Paths ---
# OGSCOPE_DATABASE_URL=sqlite:///./ogscope.db
# OGSCOPE_DATA_DIR=./data
# OGSCOPE_UPLOAD_DIR=./uploads
# OGSCOPE_ANALYSIS_DIR=./data/analysis
# OGSCOPE_PLATE_SOLVE_DIR=./data/plate_solve
# OGSCOPE_SOLVER_TETRA_DATABASE_PATH=
# OGSCOPE_STATIC_DIR=./web/static

# --- 星图解算 / Plate solve ---
# OGSCOPE_SOLVER_HINT_RA_DEG=0.0
# OGSCOPE_SOLVER_HINT_DEC_DEG=90.0
# OGSCOPE_SOLVER_FOV_DEG=11.0
# OGSCOPE_SOLVER_MAX_STARS=80
# OGSCOPE_SOLVER_FULLSOLVE_INTERVAL_FRAMES=10
# OGSCOPE_SOLVER_MAX_STARS_HARD_CAP=
# OGSCOPE_SOLVER_MAX_IMAGE_SIDE_HARD_CAP=
# OGSCOPE_SOLVER_MAX_IMAGE_SIDE=1280
# OGSCOPE_SOLVER_TIMEOUT_MS=1500

# --- 实时星空分析 / Realtime star analysis ---
# OGSCOPE_STAR_ANALYSIS_TARGET_FPS=0.6666666666666666
# OGSCOPE_STAR_ANALYSIS_MIN_INTERVAL_MS=2000
# OGSCOPE_STAR_ANALYSIS_MAX_INTERVAL_MS=12000
# OGSCOPE_STAR_ANALYSIS_REQUEST_TIMEOUT_MS=4500
# OGSCOPE_STAR_ANALYSIS_SLOW_THRESHOLD_MS=3000

# --- WiFi（也可写在 network.env）/ WiFi (may also live in network.env) ---
# OGSCOPE_WIFI_SWITCH_SCRIPT=/usr/local/bin/ogscope-wifi-switch
# OGSCOPE_WIFI_SWITCH_USE_SUDO=true
# OGSCOPE_WIFI_NMCLI_USE_SUDO=true
# OGSCOPE_WIFI_STA_ROLLBACK_TIMEOUT_SECONDS=90
# OGSCOPE_WIFI_STA_ROLLBACK_INTERVAL_SECONDS=5
