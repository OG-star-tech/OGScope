# OGScope 网络配置示例 / Network configuration example
# 部署路径 / Deploy path: /etc/ogscope/network.env
# 通常由 scripts/ogscope-network-init.sh init 生成；以下为字段说明。
# Usually generated by ogscope-network-init.sh init; fields documented below.

# --- NetworkManager 连接名（必填，否则 WiFi API 不可用）/ NM connection names (required) ---
OGSCOPE_WIFI_STA_CONNECTION=OGScope-STA
OGSCOPE_WIFI_AP_CONNECTION=OGScope-AP
OGSCOPE_WIFI_INTERFACE=wlan0

# --- 设备标识 / Device identity ---
OGSCOPE_DEVICE_ID_SUFFIX=a1b2
OGSCOPE_WIFI_AP_SSID=OGScope_a1b2

# --- STA 凭据参考（可选，供运维记录；实际连接受 NM 连接配置）/ STA credentials (optional reference) ---
# OGSCOPE_WIFI_STA_SSID=MyHomeWiFi
# OGSCOPE_WIFI_STA_PASSWORD=secret

# --- 运行时 WiFi 行为（也可写在 ogscope.env）/ Runtime WiFi (may also be in ogscope.env) ---
# OGSCOPE_WIFI_AP_URL_HOST=192.168.4.1
# OGSCOPE_WIFI_NMCLI_USE_SUDO=true
# OGSCOPE_WIFI_STA_ROLLBACK_TIMEOUT_SECONDS=90
# OGSCOPE_WIFI_STA_ROLLBACK_INTERVAL_SECONDS=5

# --- 开机网络引导 ogscope-network-boot.service（仅 shell 读取）/ Boot WiFi script only ---
# OGSCOPE_BOOT_STA_WAIT_SEC=55
# OGSCOPE_BOOT_POLL_SEC=3
# OGSCOPE_BOOT_STA_UP_RETRIES=2
# OGSCOPE_BOOT_POST_UP_WAIT=20
